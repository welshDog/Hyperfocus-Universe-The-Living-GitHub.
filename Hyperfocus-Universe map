import type { PlanetVisual } from "@/types/planetVisual";

type FocusState = "NOW" | "NEXT" | "RESTING";

type PlanetRepoInput = {
  language?: string | null;
  topics?: string[];
  stars?: number;
  forks?: number;
  openIssues?: number;
  closedIssuesRecent?: number;
  questCount?: number;
  archived?: boolean;
  hasLore?: boolean;
  focusState?: FocusState;
  releaseCount?: number;
};

const clamp = (n: number, min: number, max: number) => Math.min(max, Math.max(min, n));
const logScale = (n: number, base = 10) => Math.log(n + 1) / Math.log(base);

function getBiome(language?: string | null, topics: string[] = []) {
  const l = (language || "").toLowerCase();
  const t = topics.map((x) => x.toLowerCase()).join(" ");

  if (["typescript", "javascript"].includes(l) || t.includes("react") || t.includes("next")) {
    return {
      biome: "neon-megacity",
      baseColor: "#5DA9FF",
      accentColor: "#A66BFF",
    };
  }

  if (l === "python" || t.includes("ai") || t.includes("agent")) {
    return {
      biome: "orbital-hub",
      baseColor: "#4FD1C5",
      accentColor: "#7DD3FC",
    };
  }

  if (t.includes("docs") || t.includes("learning") || l === "markdown") {
    return {
      biome: "crystalline-library",
      baseColor: "#D6C6A5",
      accentColor: "#F8E7B5",
    };
  }

  if (t.includes("3d") || t.includes("print") || t.includes("cad") || t.includes("maker")) {
    return {
      biome: "industrial-foundry",
      baseColor: "#C9733D",
      accentColor: "#F2B35D",
    };
  }

  if (t.includes("art") || t.includes("animation") || t.includes("music") || t.includes("media")) {
    return {
      biome: "creative-workshop",
      baseColor: "#F38ACF",
      accentColor: "#8A7DFF",
    };
  }

  return {
    biome: "uncharted-world",
    baseColor: "#9AA5B1",
    accentColor: "#D9E2EC",
  };
}

export function computePlanetVisual(repo: PlanetRepoInput): PlanetVisual {
  const {
    stars = 0,
    forks = 0,
    openIssues = 0,
    closedIssuesRecent = 0,
    questCount = 0,
    archived = false,
    hasLore = false,
    focusState = "RESTING",
    releaseCount = 0,
  } = repo;

  const biomeData = getBiome(repo.language, repo.topics || []);

  const radius = clamp(0.9 + logScale(stars) * 0.5, 0.9, 2.8);
  const moonCount = clamp(Math.floor(logScale(forks) * 2), 0, 5);

  const focusBoost =
    focusState === "NOW" ? 1 :
    focusState === "NEXT" ? 0.6 :
    0.2;

  const orbitRadius =
    focusState === "NOW" ? 8 + moonCount :
    focusState === "NEXT" ? 14 + moonCount :
    22 + moonCount * 2;

  const spinSpeed = archived ? 0.001 : focusState === "NOW" ? 0.01 : focusState === "NEXT" ? 0.006 : 0.003;
  const glowIntensity = archived ? 0.08 : clamp(0.15 + focusBoost + logScale(stars) * 0.25, 0.15, 1.4);
  const stormIntensity = clamp(openIssues * 0.04 - closedIssuesRecent * 0.02, 0, 1);
  const lavaActivity = clamp(openIssues * 0.03, 0, 1);
  const questBeacons = clamp(questCount, 0, 8);
  const ringPresence = stars > 20 || releaseCount > 3 || hasLore;
  const ringDensity = ringPresence ? clamp(0.2 + logScale(releaseCount + stars) * 0.2, 0.2, 1) : 0;

  return {
    baseColor: biomeData.baseColor,
    accentColor: biomeData.accentColor,
    biome: biomeData.biome,
    radius,
    atmosphereIntensity: archived ? 0.05 : clamp(0.2 + focusBoost * 0.6, 0.1, 1),
    cloudCoverage: clamp(0.15 + stormIntensity * 0.5, 0.1, 0.9),
    ringPresence,
    ringDensity,
    moonCount,
    surfaceRoughness: clamp(0.35 + openIssues * 0.02, 0.3, 1),
    surfaceMetalness: biomeData.biome === "industrial-foundry" ? 0.45 : 0.12,
    lavaActivity,
    orbitRadius,
    orbitSpeed: archived ? 0 : focusState === "NOW" ? 0.18 : focusState === "NEXT" ? 0.11 : 0.05,
    axialTilt: hasLore ? 0.45 : 0.18,
    spinSpeed,
    glowIntensity,
    questBeacons,
    stormIntensity,
    haloPulse: archived ? 0 : clamp(releaseCount * 0.08 + focusBoost * 0.3, 0, 1),
  };
}
